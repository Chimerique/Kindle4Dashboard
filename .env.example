# Example .env for Kindle4Dashboard
# Do NOT commit sensitive values to .env; keep this as an example.

UPDATE_URL=http://192.168.0.2:8080/cover.png
WIFI_IF=wlan0
LOG_FILE=/mnt/us/frame_update.log
RETRIES=12
SLEEP_SEC=5
TMP_IMAGE=/tmp/frame.png
SAVE_PATH=/mnt/us/linkss/screensavers/ha_dashboard.png
GATEWAY_FALLBACK=192.168.0.1
